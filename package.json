{
  "name": "batch-slide",
  "version": "0.1.1",
  "private": true,
  "description": "PowerPoint task pane add-in (BatchSlide) — batch-generate slides from CSV.",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/generate-icons.js && webpack serve --mode development",
    "build": "node scripts/generate-icons.js && webpack --mode production",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate-manifest": "office-addin-manifest validate manifest/manifest.xml",
    "dev-certs:install": "office-addin-dev-certs install --machine",
    "start": "office-addin-debugging start manifest/manifest.xml desktop --app powerpoint",
    "stop": "office-addin-debugging stop manifest/manifest.xml"
  },
  "dependencies": {
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.523",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "eslint": "^9.10.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.0.7",
    "office-addin-dev-certs": "^1.13.0",
    "office-addin-manifest": "^1.13.0",
    "pngjs": "^7.0.0",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
